---
import MainLayout from '../layouts/MainLayout.astro';
import LandingHero from '../components/LandingHero-1.astro';
import FeaturedGallery from '../components/FeaturedGallery.astro';
---

<MainLayout>
	<section class="hero-section relative min-h-screen items-center flex py-20 md:py-16 overflow-hidden">
		<LandingHero />
	</section>

	<section id="what-we-do" class="featured-section pt-32 pb-20">
		<div class="container mx-auto px-3 sm:px-4 lg:px-6">
			<FeaturedGallery />
		</div>
	</section>
</MainLayout>

<style>
	.hero-section {
		-webkit-overflow-scrolling: touch;
	}

	.featured-section {
		background-color: white;
		position: relative;
		z-index: 10;
	}
</style>
