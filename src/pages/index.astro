---
import MainLayout from '../layouts/MainLayout.astro';
import LandingHero from '../components/LandingHero-1.astro';
import FeaturedGallery from '../components/FeaturedGallery.astro';
---

<MainLayout>
	<section class="hero-section relative items-center flex overflow-hidden">
		<LandingHero />
	</section>

	<section id="what-we-do" class="featured-section pt-32 pb-20">
		<div class="container mx-auto px-3 sm:px-4 lg:px-6">
			<FeaturedGallery />
		</div>
	</section>
</MainLayout>

<style>
	html {
		height: 100%;
		height: -webkit-fill-available;
	}

	body {
		min-height: 100vh;
		min-height: -webkit-fill-available;
	}

	.hero-section {
		-webkit-overflow-scrolling: touch;
		position: relative;
		width: 100%;
		height: 100vh;
		height: 100dvh;
		min-height: 100vh;
		min-height: 100dvh;
		min-height: -webkit-fill-available;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.featured-section {
		background-color: white;
		position: relative;
		z-index: 10;
	}

	/* Fallback for browsers without dvh support */
	@supports not (height: 100dvh) {
		.hero-section {
			height: calc(var(--vh, 1vh) * 100);
			min-height: calc(var(--vh, 1vh) * 100);
		}
	}
</style>

<script is:inline>
	// Set CSS variable immediately, before page renders
	(function() {
		function setViewportHeight() {
			const vh = window.innerHeight * 0.01;
			document.documentElement.style.setProperty('--vh', `${vh}px`);
		}

		setViewportHeight();
		window.addEventListener('resize', setViewportHeight);
		window.addEventListener('orientationchange', setViewportHeight);
	})();
</script>
