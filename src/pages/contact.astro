---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
	<section class="pt-48 pb-32">
		<div class="container-custom">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<!-- Left Side: Contact Info -->
				<div>
					<h1 class="text-5xl md:text-6xl font-bold mb-16">Contact</h1>

					<div class="space-y-8">
						<!-- Phone -->
						<div class="flex items-center">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
							<a href="tel:+821095500179" class="text-xl hover:underline tracking-wider">+82 10-9550-0179</a>
						</div>

						<!-- Email -->
						<div class="flex items-center">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
							<a href="mailto:legatodesign@naver.com" class="text-xl hover:underline tracking-wide">legatodesign@naver.com</a>
						</div>
					</div>
				</div>

				<!-- Right Side: Inquiry Guide -->
				<div>
					<div class="mb-4">
						<h2 class="text-3xl font-bold mb-2">견적 문의 가이드</h2>
						<p class="text-base text-gray-600">의뢰 시 아래 내용을 준비해주시면 더욱 빠르고 정확한 상담이 가능합니다.</p>
					</div>
					<div class="bg-black text-white p-12 pl-16 w-full h-[600px] flex flex-col justify-center">
						<div class="space-y-8">
							<div>
								<h3 class="text-2xl font-bold mb-3">필요하신 컷 구성 예시</h3>
								<p class="text-lg text-gray-300">ex) 단색배경 연출컷 2컷, 누끼컷 1컷, 소품 연출컷 1컷</p>
							</div>

							<div>
								<h3 class="text-2xl font-bold mb-3">참고용 연출 레퍼런스 이미지</h3>
								<p class="text-lg text-gray-300">희망하시는 연출 방향을 보다 정확하게 반영하는 데 도움이 됩니다.</p>
							</div>

							<div>
								<h3 class="text-2xl font-bold mb-3">제품 외형 확인용 이미지</h3>
								<p class="text-lg text-gray-300">정확한 견적 산정에 도움이 됩니다.</p>
							</div>

							<div>
								<h3 class="text-2xl font-bold mb-3">제품 라벨 디자인 .AI 파일</h3>
								<p class="text-lg text-gray-300">진행 시 전달 주시면 됩니다.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
