---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
const base = import.meta.env.BASE_URL;
---

<MainLayout>
	<section class="pt-48 pb-32">
		<div class="container-custom">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<img
						src=`${base}/images/${profileImage}`
						alt="Profile image"
						class="w-full h-auto"
						width="720"
						height="720"
					/>
				</div>

				<div class="prose text-gray-700 mb-6">
					<AboutPage />
				</div>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mt-32">
				<div class="prose text-gray-700 mb-6">
					<div style="font-size: 2rem; font-weight: 900; line-height: 1.6; margin-bottom: 2.5rem;">
						공간과 시간의 제약에서 완전히 자유롭습니다.
					</div>

					<div style="font-size: 1.1rem; line-height: 1.7;">
						<strong>내일 당장 필요한 제품 이미지,</strong><br>
						제품 수령부터 스튜디오 예약, 촬영, 보정까지<br>
						복잡한 과정 없이 <strong>Legato Design</strong>의 가상 스튜디오에서 한 번에 완성됩니다.<br>
						시간, 장소, 계절의 제약 없이<br>
						다양한 환경과 연출이 자유롭게 구현되며<br>
						자연광이 비치는 실내부터 무드 조명이 있는 야외까지<br>
						원하는 공간과 분위기를 그대로 재현합니다.
					</div>
				</div>

				<div>
					<img
						src=`${base}/images/${profileImage}`
						alt="Profile image"
						class="w-full h-auto"
						width="720"
						height="720"
					/>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
