---
import 'glightbox/dist/css/glightbox.css';
import '../styles/glightbox-custom.css';
import { Image, getImage } from 'astro:assets';
import type { Image as ImageType } from '../data/galleryData';

interface Props {
	images: ImageType[];
	columns?: number;
}

const { images, columns = 4 } = Astro.props;

// Generate tiny placeholder images
const placeholders = await Promise.all(
	images.map(image =>
		getImage({
			src: image.src,
			width: 20,
			height: 20,
			quality: 10,
			format: 'webp'
		})
	)
);

// Generate optimized full-size images for GLightbox (max 1920px, quality 80)
const optimizedImages = await Promise.all(
	images.map(image =>
		getImage({
			src: image.src,
			width: Math.min(image.src.width, 1920),
			quality: 80,
			format: 'webp'
		})
	)
);
---

<!-- Mobile column toggle buttons (hidden on desktop) -->
<div class="flex justify-end gap-2 mb-4 md:hidden">
	<button
		id="col-1-btn"
		class="column-toggle-btn active px-4 py-2 rounded-md border-2 transition-all duration-200"
		data-columns="1"
		aria-label="1열 보기"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
			<rect x="6" y="6" width="8" height="8" rx="1"/>
		</svg>
	</button>
	<button
		id="col-2-btn"
		class="column-toggle-btn px-4 py-2 rounded-md border-2 transition-all duration-200"
		data-columns="2"
		aria-label="2열 보기"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
			<rect x="3" y="3" width="6" height="6" rx="0.5"/>
			<rect x="11" y="3" width="6" height="6" rx="0.5"/>
			<rect x="3" y="11" width="6" height="6" rx="0.5"/>
			<rect x="11" y="11" width="6" height="6" rx="0.5"/>
		</svg>
	</button>
</div>

<section id="photo-grid" class="relative w-full mx-auto overflow-hidden" data-columns={columns} data-mobile-columns="1">
	{
		images.map((image, index) => (
			<a
				href={optimizedImages[index].src}
				class="photo-item glightbox absolute transition-transform hover:scale-[1.02] hover:z-10"
				data-gallery="gallery1"
				data-type="image"
			>
				<div class="progressive-image-container">
					<!-- Tiny blurred placeholder -->
					<img
						src={placeholders[index].src}
						class="progressive-placeholder"
						alt=""
						aria-hidden="true"
					/>
					<!-- Full quality image -->
					<Image
						src={image.src}
						quality={70}
						format="webp"
						width={image.src.width}
						height={image.src.height}
						loading="lazy"
						decoding="async"
						class="progressive-image w-full h-full object-cover rounded-sm shadow-sm hover:shadow-lg transition-shadow"
						alt={image.title}
					/>
				</div>
			</a>
		))
	}
</section>

<style>
	.column-toggle-btn {
		border-color: #e5e7eb;
		color: #6b7280;
		background-color: white;
	}

	.column-toggle-btn.active {
		border-color: #000;
		color: #000;
		background-color: #f9fafb;
	}

	.column-toggle-btn:hover {
		border-color: #9ca3af;
	}

	.column-toggle-btn.active:hover {
		border-color: #000;
	}

	/* Progressive image loading */
	.progressive-image-container {
		position: relative;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background-color: #f3f4f6;
		border-radius: 0.375rem; /* 6px rounded corners */
	}

	.progressive-placeholder {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: blur(20px);
		transform: scale(1.1);
		z-index: 1;
	}

	.progressive-image {
		position: relative;
		z-index: 2;
		opacity: 0;
		transition: opacity 0.3s ease-in-out;
	}

	.progressive-image.loaded {
		opacity: 1;
	}
</style>

<script>
	import '../scripts/photo-grid';
</script>
