---
import siteConfig from '../../site.config.mjs';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
---

<div class="hero-container">
	<!-- Mobile video background -->
	<video
		class="hero-video hero-video-mobile"
		autoplay
		loop
		muted
		playsinline
		preload="auto"
	>
		<source src={`${base}images/mobileVideo.mp4`} type="video/mp4" />
	</video>

	<!-- Desktop video background -->
	<video
		class="hero-video hero-video-desktop"
		autoplay
		loop
		muted
		playsinline
		preload="auto"
	>
		<source src={`${base}images/desktopVideo.mp4`} type="video/mp4" />
	</video>

	<div class="hero-content">
		<p class="hero-subtitle">3D 제품촬영 전문 스튜디오</p>
		<h1 class="hero-title">
			<span class="desktop-title">{owner}</span>
			<span class="mobile-title">LEGATO<br/>DESIGN</span>
		</h1>
		<a
			href="#what-we-do"
			class="hero-button"
			id="what-we-do-btn"
		>
			What We Do
		</a>
	</div>
</div>

<style>
	.hero-container {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		bottom: 0;
		z-index: 0;
		overflow: hidden;
		width: 100%;
		height: var(--vh, 100vh);
		contain: paint;
		backface-visibility: hidden;
	}

	/* Chrome - use dynamic viewport height */
	@supports (height: 100dvh) {
		.hero-container {
			height: 100dvh;
		}
	}

	/* Safari - use small viewport height */
	@supports (height: 100svh) and (-webkit-touch-callout: none) {
		.hero-container {
			height: 100svh;
		}
	}

	.hero-video {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		z-index: 1;
		pointer-events: none;
	}

	.hero-video-desktop {
		display: none;
	}

	.hero-video-mobile {
		display: block;
	}

	@media (min-width: 768px) {
		.hero-video-mobile {
			display: none;
		}

		.hero-video-desktop {
			display: block;
		}
	}

	.hero-content {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 20;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		max-width: 600px;
		padding: 0 1rem;
		width: 100%;
	}

	/* Safari adjustment - move content up slightly */
	@supports (-webkit-touch-callout: none) {
		.hero-content {
			transform: translate(-50%, -55%);
		}
	}

	@media (min-width: 768px) {
		.hero-content {
			transform: translate(-50%, -50%);
		}
	}

	.hero-subtitle {
		font-size: 0.875rem;
		color: #374151;
		margin-bottom: 0.5rem;
		width: 100%;
		max-width: 400px;
	}

	@media (min-width: 768px) {
		.hero-subtitle {
			font-size: 1.125rem;
			margin-bottom: 1rem;
		}
	}

	.hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2.5rem;
		font-weight: bold;
		line-height: 1.1;
		margin-bottom: 1rem;
		width: 100%;
		letter-spacing: 0.03em;
	}

	@media (min-width: 768px) {
		.hero-title {
			font-size: 3rem;
			line-height: 1.2;
			margin-bottom: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.hero-title {
			font-size: 3.5rem;
		}
	}

	.mobile-title {
		display: block;
	}

	.desktop-title {
		display: none;
	}

	@media (min-width: 768px) {
		.mobile-title {
			display: none;
		}
		.desktop-title {
			display: inline;
		}
	}

	.hero-button {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		border: 2px solid black;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: black;
		background-color: transparent;
		transition: all 0.3s ease;
		transform: scale(1);
		animation: pulse-border 2s ease-in-out infinite;
		text-decoration: none;
		width: auto;
	}

	@media (min-width: 768px) {
		.hero-button {
			padding: 1rem 2rem;
			font-size: 1.125rem;
		}
	}

	/* Only apply hover on desktop */
	@media (hover: hover) and (pointer: fine) {
		.hero-button:hover {
			background-color: black;
			color: white;
			transform: scale(1.05);
		}
	}

	/* Active state for touch - brief visual feedback only */
	.hero-button:active {
		transform: scale(0.95);
		transition: transform 0.1s ease;
	}

	/* Prevent sticky active state on mobile */
	.hero-button:focus {
		outline: none;
	}

	.hero-button:focus-visible {
		outline: 2px solid black;
		outline-offset: 2px;
	}

	@keyframes pulse-border {
		0% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0.7);
		}
		50% {
			box-shadow: 0 0 12px 4px rgba(0, 0, 0, 0.4);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0);
		}
	}
</style>

<script>
	// Fix viewport height on initial load - use visualViewport if available
	function setInitialViewportHeight() {
		let vh: number;

		if (window.visualViewport) {
			vh = window.visualViewport.height;
			console.log('[Hero] Using visualViewport.height:', vh);
		} else {
			vh = window.innerHeight;
			console.log('[Hero] Using window.innerHeight:', vh);
		}

		// Set CSS variable as fallback
		document.documentElement.style.setProperty('--vh', `${vh}px`);

		// Log browser info for debugging
		const ua = navigator.userAgent;
		const isSafari = /Safari/.test(ua) && !/Chrome/.test(ua);
		const isChrome = /Chrome/.test(ua);
		console.log('[Hero] Browser:', isSafari ? 'Safari' : isChrome ? 'Chrome' : 'Other');
		console.log('[Hero] Initial viewport height set to:', vh, 'px');
	}

	// Set on load - only once to prevent resize during scroll
	setInitialViewportHeight();

	// Only update on orientation change, not during scroll
	let orientationChangeTimer: number;
	window.addEventListener('resize', () => {
		// Ignore small resize events (likely address bar showing/hiding)
		const currentOrientation = window.screen?.orientation?.angle ?? (window.orientation as number);

		clearTimeout(orientationChangeTimer);
		orientationChangeTimer = window.setTimeout(() => {
			const newOrientation = window.screen?.orientation?.angle ?? (window.orientation as number);
			if (currentOrientation !== newOrientation) {
				console.log('[Hero] Orientation changed, updating viewport height');
				setInitialViewportHeight();
			}
		}, 300);
	});

	// Handle page visibility changes (app switching on mobile)
	const videos = document.querySelectorAll('.hero-video') as NodeListOf<HTMLVideoElement>;

	document.addEventListener('visibilitychange', () => {
		if (!document.hidden) {
			// Page is visible again - resume video if paused
			videos.forEach(video => {
				if (video.paused) {
					video.play().catch(err => {
						console.log('Video play prevented:', err);
					});
				}
			});
		}
	});

	// Smooth scroll for What We Do button only
	const whatWeDoBtn = document.getElementById('what-we-do-btn');
	if (whatWeDoBtn) {
		whatWeDoBtn.addEventListener('click', (e) => {
			e.preventDefault();

			// Remove focus/active state immediately on mobile
			(e.currentTarget as HTMLElement).blur();

			const target = document.querySelector('#what-we-do');
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});

		// Also handle touchend to ensure active state is removed on mobile
		whatWeDoBtn.addEventListener('touchend', (e) => {
			setTimeout(() => {
				(e.currentTarget as HTMLElement).blur();
			}, 100);
		});
	}
</script>
