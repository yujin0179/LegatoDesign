---
import siteConfig from '../../site.config.mjs';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
---

<div class="hero-container">
	<!-- Mobile video background -->
	<video
		class="hero-video hero-video-mobile"
		autoplay
		muted
		playsinline
		preload="auto"
	>
		<source src={`${base}images/mobileVideo.mp4`} type="video/mp4" />
	</video>

	<!-- Desktop video background -->
	<video
		class="hero-video hero-video-desktop"
		autoplay
		muted
		playsinline
		preload="auto"
	>
		<source src={`${base}images/desktopVideo.mp4`} type="video/mp4" />
	</video>

	<div class="hero-content">
		<p class="hero-subtitle">3D 제품촬영 전문 스튜디오</p>
		<h1 class="hero-title">
			<span class="desktop-title">{owner}</span>
			<span class="mobile-title">Legato<br/>Design</span>
		</h1>
		<a
			href="#what-we-do"
			class="hero-button"
		>
			What We Do
		</a>
	</div>
</div>

<style>
	.hero-container {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		bottom: 0;
		z-index: 0;
		overflow: hidden;
	}

	.hero-video {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		z-index: 1;
	}

	.hero-video-desktop {
		display: none;
	}

	.hero-video-mobile {
		display: block;
	}

	@media (min-width: 768px) {
		.hero-video-mobile {
			display: none;
		}

		.hero-video-desktop {
			display: block;
		}
	}

	.hero-content {
		position: relative;
		z-index: 20;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		text-align: center;
		height: 100%;
		max-width: 600px;
		margin: 0 auto;
		padding: 0 1rem;
		padding-top: 30vh;
	}

	@media (min-width: 768px) {
		.hero-content {
			padding-top: 30vh;
		}
	}

	.hero-subtitle {
		font-size: 1rem;
		color: #374151;
		margin-bottom: 0.75rem;
		width: 100%;
		max-width: 400px;
	}

	@media (min-width: 768px) {
		.hero-subtitle {
			font-size: 1.125rem;
			margin-bottom: 1rem;
		}
	}

	.hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: 3rem;
		font-weight: bold;
		line-height: 1.2;
		margin-bottom: 1.5rem;
		width: 100%;
	}

	@media (min-width: 768px) {
		.hero-title {
			font-size: 3rem;
			margin-bottom: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.hero-title {
			font-size: 3.5rem;
		}
	}

	.mobile-title {
		display: block;
	}

	.desktop-title {
		display: none;
	}

	@media (min-width: 768px) {
		.mobile-title {
			display: none;
		}
		.desktop-title {
			display: inline;
		}
	}

	.hero-button {
		display: inline-block;
		padding: 1rem 2rem;
		border: 2px solid black;
		border-radius: 0.375rem;
		font-size: 1rem;
		font-weight: 500;
		color: black;
		background-color: transparent;
		transition: all 0.3s ease;
		transform: scale(1);
		animation: pulse-border 2s ease-in-out infinite;
		text-decoration: none;
		width: auto;
	}

	@media (min-width: 768px) {
		.hero-button {
			font-size: 1.125rem;
		}
	}

	.hero-button:hover {
		background-color: black;
		color: white;
		transform: scale(1.05);
	}

	.hero-button:active {
		transform: scale(0.95);
	}

	@keyframes pulse-border {
		0% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0.7);
		}
		50% {
			box-shadow: 0 0 12px 4px rgba(0, 0, 0, 0.4);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0);
		}
	}
</style>

<script>
	// Play videos once and keep last frame
	const videos = document.querySelectorAll('.hero-video') as NodeListOf<HTMLVideoElement>;
	videos.forEach(video => {
		video.addEventListener('ended', () => {
			video.pause();
		});
	});
</script>
