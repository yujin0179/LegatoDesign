---
import siteConfig from '../../site.config.mjs';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
---

<div class="hero-container">
	<div class="hero-content">
		<p class="hero-subtitle">3D 제품촬영 전문 스튜디오</p>
		<h1 class="hero-title">
			<span class="desktop-title">{owner}</span>
			<span class="mobile-title">LEGATO<br/>DESIGN</span>
		</h1>
		<a
			href="#what-we-do"
			class="hero-button"
			id="what-we-do-btn"
		>
			What We Do
		</a>
	</div>
</div>

<style>
	.hero-container {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		bottom: 0;
		z-index: 0;
		overflow: hidden;
		width: 100%;
		height: 100%;
		min-height: 100vh;
		min-height: 100dvh;
		min-height: -webkit-fill-available;
		background-color: white;
	}

	.hero-content {
		position: relative;
		z-index: 20;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		height: 100%;
		max-width: 600px;
		margin: 0 auto;
		padding: 0 1rem;
	}

	.hero-subtitle {
		font-size: 0.875rem;
		color: #374151;
		margin-bottom: 0.5rem;
		width: 100%;
		max-width: 400px;
	}

	@media (min-width: 768px) {
		.hero-subtitle {
			font-size: 1.125rem;
			margin-bottom: 1rem;
		}
	}

	.hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2.5rem;
		font-weight: bold;
		line-height: 1.1;
		margin-bottom: 1rem;
		width: 100%;
		letter-spacing: 0.03em;
	}

	@media (min-width: 768px) {
		.hero-title {
			font-size: 3rem;
			line-height: 1.2;
			margin-bottom: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.hero-title {
			font-size: 3.5rem;
		}
	}

	.mobile-title {
		display: block;
	}

	.desktop-title {
		display: none;
	}

	@media (min-width: 768px) {
		.mobile-title {
			display: none;
		}
		.desktop-title {
			display: inline;
		}
	}

	.hero-button {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		border: 2px solid black;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: black;
		background-color: transparent;
		transition: all 0.3s ease;
		transform: scale(1);
		animation: pulse-border 2s ease-in-out infinite;
		text-decoration: none;
		width: auto;
	}

	@media (min-width: 768px) {
		.hero-button {
			padding: 1rem 2rem;
			font-size: 1.125rem;
		}
	}

	/* Only apply hover on desktop */
	@media (hover: hover) and (pointer: fine) {
		.hero-button:hover {
			background-color: black;
			color: white;
			transform: scale(1.05);
		}
	}

	/* Active state for touch - brief visual feedback only */
	.hero-button:active {
		transform: scale(0.95);
		transition: transform 0.1s ease;
	}

	/* Prevent sticky active state on mobile */
	.hero-button:focus {
		outline: none;
	}

	.hero-button:focus-visible {
		outline: 2px solid black;
		outline-offset: 2px;
	}

	@keyframes pulse-border {
		0% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0.7);
		}
		50% {
			box-shadow: 0 0 12px 4px rgba(0, 0, 0, 0.4);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(0, 0, 0, 0);
		}
	}
</style>

<script>
	// Smooth scroll for What We Do button only
	const whatWeDoBtn = document.getElementById('what-we-do-btn');
	if (whatWeDoBtn) {
		whatWeDoBtn.addEventListener('click', (e) => {
			e.preventDefault();

			// Remove focus/active state immediately on mobile
			(e.currentTarget as HTMLElement).blur();

			const target = document.querySelector('#what-we-do');
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});

		// Also handle touchend to ensure active state is removed on mobile
		whatWeDoBtn.addEventListener('touchend', (e) => {
			setTimeout(() => {
				(e.currentTarget as HTMLElement).blur();
			}, 100);
		});
	}
</script>
