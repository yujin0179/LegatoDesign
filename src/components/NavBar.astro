---
import siteConfig from '../../site.config.mjs';

const title = siteConfig.title;

const base = import.meta.env.BASE_URL;
const menuItems = [
	{ name: 'Works', link: `${base}collections/product` },
	{ name: 'About', link: `${base}about` },
	{ name: 'Contact', link: `${base}contact` },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&display=swap"
	rel="stylesheet"
/>

<nav
	x-data="{ isOpen: false, scrolled: false }"
	@scroll.window="scrolled = window.scrollY > 50"
	class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
	:class="scrolled ? 'py-3 bg-white shadow-sm' : 'py-5 bg-transparent'"
>
	<div class="container mx-auto px-3 sm:px-4 lg:px-6 flex justify-between items-center">
		<a href={base} id="logo" class="text-2xl md:text-4xl font-semibold tracking-tight" style="font-family: 'Cormorant Garamond', serif;">
			{title}
		</a>

		<!-- Desktop Menu (Center) -->
		<div class="hidden md:flex absolute left-1/2 transform -translate-x-1/2 space-x-8">
			{
				menuItems.map((item) => (
					<a
						href={item.link}
						class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all"
					>
						{item.name}
					</a>
				))
			}
		</div>

		<!-- Price Button (Desktop) -->
		<a
			href={`${base}pricing`}
			class="hidden md:block bg-black text-white font-bold px-6 py-2 rounded-full hover:bg-gray-800 transition-colors"
		>
			가격안내
		</a>

		<!-- Mobile Menu Button -->
		<button @click="isOpen = !isOpen" class="md:hidden text-gray-800 focus:outline-none">
			<svg x-show="!isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M4 6h16M4 12h16M4 18h16"></path>
			</svg>
			<svg x-show="isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div x-show="isOpen" class="md:hidden absolute top-full left-0 w-full bg-white shadow-md">
		<div class="flex flex-col py-4 px-6 space-y-4">
			{
				menuItems.map((item) => (
					<a href={item.link} class="text-lg" @click="isOpen = false">
						{item.name}
					</a>
				))
			}
			<a
				href={`${base}pricing`}
				class="text-lg font-bold bg-black text-white px-6 py-3 rounded-full text-center hover:bg-gray-800 transition-colors"
				@click="isOpen = false"
			>
				가격안내
			</a>
		</div>
	</div>
</nav>
