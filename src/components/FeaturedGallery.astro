---
import { Image } from 'astro:assets';
import W1 from '../gallery/whatWeDo/W1.png';
import W2 from '../gallery/whatWeDo/W2.jpg';
import W3 from '../gallery/whatWeDo/W3.jpg';

const cards = [
	{
		title: '배경이 없는 제품 단독 이미지',
		image: W1
	},
	{
		title: '제품이 돋보이는 단색배경 이미지',
		image: W2
	},
	{
		title: '오브제, 조명, 구도를 활용해 연출한<br>감각적인 이미지',
		image: W3
	}
];
---

<div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
	<h2 class="text-2xl md:text-4xl font-bold mb-4">What We Do</h2>
</div>

<div class="what-we-do-container">
	<div class="what-we-do-grid">
		{cards.map((card) => (
			<div class="card-item">
				<h3 class="card-title" style="word-break: keep-all;">
					<Fragment set:html={card.title} />
				</h3>
				<div class="card-image-wrapper">
					<Image
						src={card.image}
						alt={card.title}
						quality={90}
						loading="lazy"
						class="card-image"
					/>
				</div>
			</div>
		))}
	</div>
</div>

<style>
	.what-we-do-container {
		width: 100%;
		margin: 0 auto;
		padding: 0;
	}

	.what-we-do-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.what-we-do-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
			align-items: end;
		}
	}

	.card-item {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.card-title {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		font-weight: 600;
		text-align: center;
		margin: 0;
		color: #1f2937;
		word-break: keep-all;
	}

	@media (min-width: 768px) {
		.card-title {
			font-size: 1.125rem;
		}
	}

	.card-image-wrapper {
		width: 100%;
		overflow: hidden;
	}

	.card-image {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.3s ease;
	}

	/* Hover effect only on desktop */
	@media (hover: hover) and (pointer: fine) {
		.card-image-wrapper:hover .card-image {
			transform: scale(1.05);
		}
	}
</style>

<div class="view-works-container">
	<a
		href="/collections/product"
		class="inline-block px-8 py-3 border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-base font-medium transform hover:scale-105"
	>
		View Works
	</a>
</div>

<style>
	.view-works-container {
		width: 100%;
		margin: 3rem auto 0;
		padding: 0;
		display: flex;
		justify-content: flex-end;
	}
</style>
