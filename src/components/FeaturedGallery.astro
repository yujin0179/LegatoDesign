---
import { featuredCollectionId, getImages } from '../data/imageStore';

const images = await getImages({ collection: featuredCollectionId });

const cardData = [
	{
		title: '배경이 없는 제품 단독 이미지',
		image: images[0]
	},
	{
		title: '제품이 돋보이는 단색배경 이미지',
		image: images[1]
	},
	{
		title: '오브제, 조명등을 사용해 연출한 감각적인 이미지',
		image: images[2]
	}
];
---

<div class="max-w-2xl mx-auto text-center mb-16">
	<h2 class="text-3xl md:text-4xl font-bold mb-4">What We Do</h2>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
	{cardData.map((card) => (
		<div class="bg-white rounded-lg shadow-lg overflow-hidden">
			<div class="p-6 text-center">
				<h3 class="text-lg font-semibold mb-4">{card.title}</h3>
			</div>
			<div class="aspect-square overflow-hidden">
				{card.image && (
					<img
						src={card.image.src.src}
						alt={card.image.title || card.title}
						class="w-full h-full object-cover"
					/>
				)}
			</div>
		</div>
	))}
</div>
