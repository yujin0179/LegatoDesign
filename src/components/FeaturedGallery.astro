---
---

<div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
	<h2 class="text-2xl md:text-4xl font-bold mb-4">What We Do</h2>
</div>

<div class="what-we-do-grid">
	<!-- Cards will be added here -->
</div>

<style>
	.what-we-do-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		max-width: 24rem;
		margin: 0 auto;
		padding: 0 0.5rem;
	}

	@media (min-width: 768px) {
		.what-we-do-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
			max-width: none;
			padding: 0;
		}
	}
</style>

<div class="view-works-container">
	<a
		href="/collections/product"
		class="inline-block px-8 py-3 border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-base font-medium transform hover:scale-105"
	>
		View Works
	</a>
</div>

<style>
	.view-works-container {
		display: flex;
		justify-content: flex-end;
		margin-top: 3rem;
		max-width: 24rem;
		margin-left: auto;
		margin-right: auto;
		padding: 0 0.5rem;
	}

	@media (min-width: 768px) {
		.view-works-container {
			max-width: none;
			padding: 0;
		}
	}
</style>
