---
import { featuredCollectionId, getImages } from '../data/imageStore';

const images = await getImages({ collection: featuredCollectionId });
const base = import.meta.env.BASE_URL;

const cardData = [
	{
		title: '배경이 없는 제품 단독 이미지',
		image: images[0]
	},
	{
		title: '제품이 돋보이는 단색배경 이미지',
		image: images[1]
	},
	{
		title: '오브제, 조명, 구도를 활용해 연출한 감각적인 이미지',
		image: images[2]
	}
];
---

<div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
	<h2 class="text-2xl md:text-4xl font-bold mb-4">What We Do</h2>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mx-auto px-8 md:px-0 max-w-sm md:max-w-none">
	{cardData.map((card) => (
		<div class="bg-white rounded-lg shadow-lg overflow-hidden md:transition-all md:duration-300 md:hover:scale-105 md:hover:-translate-y-2">
			<div class="p-4 md:p-6 text-center">
				<h3 class="text-base md:text-lg font-semibold mb-3 md:mb-4">{card.title}</h3>
			</div>
			<div class="aspect-square overflow-hidden">
				{card.image && (
					<img
						src={card.image.src.src}
						alt={card.image.title || card.title}
						class="w-full h-full object-cover"
					/>
				)}
			</div>
		</div>
	))}
</div>

<div class="flex justify-end mt-12">
	<a
		href="/collections/product"
		class="inline-block px-8 py-3 border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-base font-medium transform hover:scale-105"
	>
		View Works
	</a>
</div>
