---
import { Image } from 'astro:assets';
import { featuredCollectionId, getImages } from '../data/imageStore';

const images = await getImages({ collection: featuredCollectionId });

const cardData = [
	{
		title: '배경이 없는 제품 단독 이미지',
		image: images[0]
	},
	{
		title: '제품이 돋보이는 단색배경 이미지',
		image: images[1]
	},
	{
		title: '오브제, 조명, 구도를 활용해 연출한 감각적인 이미지',
		image: images[2]
	}
];
---

<div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
	<h2 class="text-2xl md:text-4xl font-bold mb-4">What We Do</h2>
</div>

<div class="what-we-do-grid">
	{cardData.map((card) => (
		<div class="what-we-do-card">
			<div class="card-text">
				<h3>{card.title}</h3>
			</div>
			<div class="card-image">
				{card.image && (
					<Image
						src={card.image.src}
						alt={card.image.title || card.title}
						quality={90}
						format="png"
						width={card.image.src.width}
						height={card.image.src.height}
						loading="lazy"
						decoding="async"
					/>
				)}
			</div>
		</div>
	))}
</div>

<style>
	.what-we-do-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		max-width: 24rem;
		margin: 0 auto;
		padding: 0 0.5rem;
	}

	@media (min-width: 768px) {
		.what-we-do-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
			max-width: none;
			padding: 0;
		}
	}

	.what-we-do-card {
		background: white;
		border-radius: 0.5rem;
		overflow: hidden;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
	}

	.card-text {
		padding: 1rem 1.5rem;
		text-align: center;
	}

	.card-text h3 {
		font-size: 1rem;
		font-weight: 600;
		margin: 0;
	}

	@media (min-width: 768px) {
		.card-text {
			padding: 1.5rem;
		}
		.card-text h3 {
			font-size: 1.125rem;
		}
	}

	.card-image {
		width: 100%;
		position: relative;
		padding-bottom: 100%; /* aspect-ratio 1:1 */
	}

	.card-image img {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
		transform: translate3d(0, 0, 0);
		-webkit-transform: translate3d(0, 0, 0);
	}

	/* Desktop hover effect */
	@media (hover: hover) and (pointer: fine) {
		.what-we-do-card {
			transition: transform 0.3s ease;
		}

		.what-we-do-card:hover {
			transform: scale(1.05) translateY(-0.5rem);
		}
	}
</style>

<div class="view-works-container">
	<a
		href="/collections/product"
		class="inline-block px-8 py-3 border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-base font-medium transform hover:scale-105"
	>
		View Works
	</a>
</div>

<style>
	.view-works-container {
		display: flex;
		justify-content: flex-end;
		margin-top: 3rem;
		max-width: 24rem;
		margin-left: auto;
		margin-right: auto;
		padding: 0 0.5rem;
	}

	@media (min-width: 768px) {
		.view-works-container {
			max-width: none;
			padding: 0;
		}
	}
</style>
